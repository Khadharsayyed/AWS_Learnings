pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "khadhar27/sample-web"
        DOCKER_TAG = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                // Pull latest code from your public GitHub repo
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    // Build using Dockerfile named Docker2
                    sh "docker build -f Docker2 -t ${DOCKER_IMAGE}:${DOCKER_TAG} ."
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    // Push to Docker Hub (docker-cred must be configured in Jenkins)
                    withDockerRegistry([credentialsId: 'docker-cred', url: 'https://index.docker.io/v1/']) {
                        sh "docker push ${DOCKER_IMAGE}:${DOCKER_TAG}"
                    }
                }
            }
        }

        stage('Run Container Test') {
            steps {
                script {
                    // Run container locally to verify sample.html is served
                    sh "docker run -d -p 8080:80 ${DOCKER_IMAGE}:${DOCKER_TAG}"
                }
            }
        }
    }
}
